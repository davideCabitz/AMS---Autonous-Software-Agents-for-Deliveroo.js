# Deliveroo agent connection
TOKEN=your_jwt_token_here
HOST="http://localhost:8080"

# Two-agent launcher (node myAgent/launch.js coordinator|worker)
TOKEN_COORDINATOR=coordinator_jwt_token_here
TOKEN_WORKER=worker_jwt_token_here

# LLM command layer (optional — omit to run BDI only)
LITELLM_BASE_URL="https://your-litellm-endpoint/v1"
LITELLM_API_KEY=your_api_key_here
LOCAL_MODEL=gpt-4o
LOCAL_MODEL_FALLBACK=

# Exploration strategy: leave unset for deterministic, set to "stochastic" for probabilistic group sampling
# EXPLORE_MODE=stochastic

# Logging — comma-separated namespaces, * for all, empty for silent
# See Logger.md for the full list of available namespaces
LOG_NAMESPACES=*
