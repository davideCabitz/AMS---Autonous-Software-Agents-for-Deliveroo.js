# Game server JWT token (obtained from the Deliveroo.js server on login)
TOKEN=your_jwt_token_here

# Game server URL
HOST="http://localhost:8080"

# LiteLLM proxy base URL (optional — only needed for the LLM command layer)
LITELLM_BASE_URL="https://your-litellm-proxy/v1"

# LiteLLM API key (optional — BDI agent runs without it)
LITELLM_API_KEY=sk-your_api_key_here

# Model identifier forwarded to the LiteLLM proxy
LOCAL_MODEL=gpt-4o
